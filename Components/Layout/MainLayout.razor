@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">EduCore Pro</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Главная</MudNavLink>
            <MudNavLink Href="/methodist" Icon="@Icons.Material.Filled.Book">Методист (РПД)</MudNavLink>
            <MudNavLink Href="/slidemaster" Icon="@Icons.Material.Filled.Slideshow">Слайды</MudNavLink>
            <MudNavLink Href="/testcenter" Icon="@Icons.Material.Filled.Quiz">Тест-Центр</MudNavLink>
            <MudNavLink Href="/grading" Icon="@Icons.Material.Filled.Grading">ИИ-Проверка</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-6 pb-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}