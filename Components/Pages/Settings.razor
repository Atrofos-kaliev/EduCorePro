@page "/settings"
@using EduCorePro.Services
@inject SettingsService SettingsService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" GutterBottom="true">Настройки системы</MudText>

<MudPaper Class="pa-6" MaxWidth="600px" Elevation="3">
    <MudText Typo="Typo.h6" GutterBottom="true">API Ключ</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
        Ваш ключ надежно шифруется с помощью Windows DPAPI. Он хранится только на этом ПК и никогда не передается третьим лицам.
    </MudText>
    
    <MudTextField @bind-Value="_apiKey" Label="Введите API Key" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
    
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save">
        Сохранить ключ
    </MudButton>
</MudPaper>

@code {
    private string _apiKey = "";

    protected override void OnInitialized()
    {
        _apiKey = SettingsService.GetApiKey();
    }

    private void SaveSettings()
    {
        SettingsService.SaveApiKey(_apiKey);
        Snackbar.Add("Настройки успешно сохранены и зашифрованы!", Severity.Success);
    }
}